{
    "name": "ermakk/laravel-gis-meteo",
    "description": "Laravel package for GisMeteo weather API",
    "type": "library",
    "minimum-stability": "stable",
    "license": "MIT",
    "authors": [
        {
            "name": "liv",
            "email": "los-van@mail.ru"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0",
        "saloonphp/saloon": "v3.11.1"
    },
    "autoload": {
        "psr-4": {
            "Ermakk\\GisMeteo\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ermakk\\GisMeteo\\GisMeteoServiceProvider"
            ],
            "aliases": {
                "Weather": "Ermakk\\GisMeteo\\Facades\\Weather"
            }
        }
    }
}
